# JWT Authentication and Tasks API - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration (Neon PostgreSQL)
# ============================================
# Get your connection string from https://neon.tech
# Format: postgresql+psycopg://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg://user:password@ep-xxx.us-east-1.aws.neon.tech/dbname?sslmode=require

# ============================================
# JWT Settings
# ============================================
# Generate a secure secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MUST be at least 32 characters
SECRET_KEY=change-this-to-a-secure-random-string-at-least-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================
# Application Settings
# ============================================
APP_ENV=development
DEBUG=true
APP_NAME=JWT Auth and Tasks API
APP_VERSION=1.0.0

# ============================================
# Server Configuration
# ============================================
HOST=0.0.0.0
PORT=8000
